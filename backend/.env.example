SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Local dev: sqlite:///./postpilot.db
# Production: postgresql://user:password@host:5432/postpilot
DATABASE_URL=sqlite:///./postpilot.db

ENCRYPTION_KEY=change-this-to-a-32-byte-fernet-key

# Cloudinary (for image storage in production)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
